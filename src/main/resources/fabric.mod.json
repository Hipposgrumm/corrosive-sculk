{
  "schemaVersion": 1,
  "id": "${modid}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${author}"
  ],
  "contact": {
    "sources": "https://github.com/Hipposgrumm/corrosive-sculk",
    "homepage": "https://github.com/Hipposgrumm/corrosive-sculk",
    "issues": "https://github.com/Hipposgrumm/corrosive-sculk/issues"
  },
  "license": "${license}",
  "icon": "${modid}.png",
  "environment": "*",
  "accessWidener" : "${modid}.accesswidener",
  "entrypoints": {
    "main": [
      "${group}.${modid}.CorrosiveSculk"
    ],
    "client": [
      "${group}.${modid}.CorrosiveSculkClientside"
    ],
    "modmenu": [
      "${group}.${modid}.config.ModMenuAccess"
    ]
  },
  "mixins": [
    "${modid}.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_version}",
    "fabric": ">=${fabric_api_version}+${minecraft_version}",
    "minecraft": "${minecraft_dep}"
  },
  "suggests": {
    "cloth-config": ">=${cloth_version}",
    "modmenu": ">=${modmenu_version}"
  }
}
