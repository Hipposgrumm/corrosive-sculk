{
  "schemaVersion": 1,
  "id": "${modid}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${author}"
  ],
  "contact": {},
  "license": "${license}",
  "icon": "assets/${modid}/mod.png",
  "environment": "*",
  "accessWidener" : "${modid}.accesswidener",
  "entrypoints": {
    "main": [
      "${group}.${modid}.ExampleModMain"
    ]
  },
  "mixins": [
    "${modid}.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_version}",
    "fabric": ">=${fabric_api_version}+${minecraft_version}",
    "minecraft": "${minecraft_dep}"
  }
}
