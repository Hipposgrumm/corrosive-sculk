{
  "required": true,
  "package": "dev.hipposgrumm.${modid}.mixin",
  "compatibilityLevel": "${mixin_java_version}",
  "refmap": "${modid}.mixins.refmap.json",
  "mixins": [
    "MixinLivingEntity",
    "MixinPlayer"
  ],
  "client": [
    //? if forgebase {
      //? if =1.20.1
      "MixinDisableMantleHeartsRender",
    "MixinForgeGui",
    //?}
    "MixinGui"
  ],
  "minVersion": "0.8",
  "mixinextras": {"minVersion": "0.5.0"}
}